{
  "datasets": [
    {
      "name": "540ed332",
      "displayName": "EarthQuake_Detail",
      "queryLines": [
        "select * from silver.earthquake_data_final;"
      ],
      "catalog": "youtube_prod",
      "schema": "default"
    },
    {
      "name": "47f91550",
      "displayName": "Magnitude_Type",
      "queryLines": [
        "select\r\n",
        "  count(*) as total_magnitude_bucket,\r\n",
        "  magnitude_bucket\r\n",
        "from\r\n",
        "  (\r\n",
        "    select\r\n",
        "      case\r\n",
        "        when mag < 2 then 'Micro (<2)'\r\n",
        "        when mag between 2 and 3 then 'Minor (2-3)'\r\n",
        "        when mag between 3 and 4 then 'Light (3-4)'\r\n",
        "        else 'Moderate+ (4+)'\r\n",
        "      end as magnitude_bucket\r\n",
        "    from\r\n",
        "      youtube_dev.silver.earthquake_data\r\n",
        "  )\r\n",
        "group by\r\n",
        "  magnitude_bucket"
      ]
    },
    {
      "name": "1740ab53",
      "displayName": "Earthquake_country",
      "queryLines": [
        "select\r\n",
        "  count(*) as event_count,\r\n",
        "  get(split(place, ','), 1) as country\r\n",
        "from\r\n",
        "  (\r\n",
        "    select\r\n",
        "      time,\r\n",
        "      title,\r\n",
        "      mag,\r\n",
        "      longitude,\r\n",
        "      place,\r\n",
        "      latitude\r\n",
        "    from\r\n",
        "      youtube_dev.silver.earthquake_data_final\r\n",
        "  )\r\n",
        "group by\r\n",
        "  country"
      ]
    }
  ],
